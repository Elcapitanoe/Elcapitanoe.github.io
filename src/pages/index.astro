---
import Layout from "../layouts/Layout.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import Header from "../components/Header.astro";
import Bio from "../components/Bio.astro";
import Skills from "../components/Skills.astro";
import Contact from "../components/Contact.astro";
---

<Layout
    title="Domi Adiwijaya | Tech & HomeLab Enthusiast"
    description="Personal portfolio of Domi Adiwijaya, a Tech & HomeLab Enthusiast specializing in System Administration, Home Automation, and Linux Systems."
>
    <ThemeToggle />

    <div class="paper-sheet">
        <div class="paper-content">
            <Header />

            <main class="main">
                <Bio />
                <Skills />
                <Contact />
            </main>

            <footer class="footer">
                <p>
                    &copy; 2026 Domi Adiwijaya. Built with passion for
                    technology.
                </p>
            </footer>
        </div>
    </div>
</Layout>
